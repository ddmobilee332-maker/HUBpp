                TracerLine.To = Vector2.new(screenPos.X, screenPos.Y)
                TracerLine.Color = _G.TracerRainbow and tracerRainbowColor or _G.TracerColor
                TracerLine.Visible = true
            else TracerLine.Visible = false end
        else TracerLine.Visible = false end
